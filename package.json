{
  "name": "@drask-dev/scan",
  "version": "0.6.3",
  "description": "PII detection engine — regex patterns and NER for structured and unstructured PII",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "author": "Drask <hello@drask.dev> (https://drask.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/drask-dev/scan.git"
  },
  "homepage": "https://github.com/drask-dev/scan#readme",
  "bugs": {
    "url": "https://github.com/drask-dev/scan/issues"
  },
  "keywords": [
    "pii",
    "detection",
    "redaction",
    "privacy",
    "ner",
    "compliance",
    "gdpr",
    "data-protection"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.26.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "compromise": "^14.15.0"
  }
}
